{
  "expo": {
    "name": "yarsplitkarega",
    "slug": "yarsplitkarega",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0E17",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yarsplitkarega.app"
    },
    "android": {
      "package": "com.yarsplitkarega.app",
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "yarsplitkarega.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "yarsplitkarega"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F0E17"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "yarsplitkarega needs camera access to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "yarsplitkarega needs photo library access to attach receipts."
        }
      ],
      "expo-font"
    ],
    "scheme": "yarsplitkarega",
    "extra": {
      "eas": {
        "projectId": "80cbbfff-e4a9-4558-b9dc-72b73a4ae923"
      }
    },
    "owner": "priyanshupriy6"
  }
}
